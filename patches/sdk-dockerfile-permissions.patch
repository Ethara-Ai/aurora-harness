diff --git a/openhands-agent-server/openhands/agent_server/docker/Dockerfile b/openhands-agent-server/openhands/agent_server/docker/Dockerfile
index 345ecd75..e4573b01 100644
--- a/openhands-agent-server/openhands/agent_server/docker/Dockerfile
+++ b/openhands-agent-server/openhands/agent_server/docker/Dockerfile
@@ -55,6 +55,9 @@ RUN test -x /agent-server/dist/openhands-agent-server
 FROM ${BASE_IMAGE} AS base-image-minimal
 ARG USERNAME UID GID PORT
 
+# Ensure we run as root for package installation (base images may have non-root default user)
+USER root
+
 # Install base packages and create user
 RUN set -eux; \
     # Remove Azul Zulu repo if present - it may have stale metadata that causes apt-get update
@@ -80,6 +83,19 @@ RUN set -eux; \
     chown -R ${USERNAME}:${USERNAME} /workspace; \
     rm -rf /var/lib/apt/lists/*
 
+# Fix permissions on repository directories so openhands user can read all files
+# Base images may have restrictive permissions on .git/objects/pack/*.promisor files
+RUN set -eux; \
+    for dir in /testbed /app/repo /home/*/repo /home/*/.git; do \
+        if [ -d "$dir" ] || [ -L "$dir" ]; then \
+            chmod -R a+rX "$dir" 2>/dev/null || true; \
+        fi; \
+    done; \
+    # Also fix any .git directories specifically (often have restrictive pack file permissions)
+    find /testbed /app /home -name '.git' -type d 2>/dev/null | while read gitdir; do \
+        chmod -R a+rX "$gitdir" 2>/dev/null || true; \
+    done || true
+
 # NOTE: we should NOT include UV_PROJECT_ENVIRONMENT here, 
 # since the agent might use it to perform other work (e.g. tools that use Python)
 COPY --from=ghcr.io/astral-sh/uv /uv /uvx /bin/
